rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User progress
    match /users/{userId} {
      // Allow user to read their own profile (if we use Firebase Auth linking later)
      // For now, we only allow admin/server-side access unless linked.
      // But let's assume we might use client-side reading for progress.
      // allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Public leaderboard reading if needed
      allow list: if true; // In a real production app, you might restrict this.
      allow get: if true;
      
      // Deny all client-side writes to enforce server-side authority (Telegram Bot/API)
      allow write: if false; 
    }

    // Logs
    match /logs/{logId} {
      // Logs are write-only from server, generally no client access needed.
      allow read, write: if false;
    }
  }
}
