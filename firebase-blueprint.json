{
  "entities": {
    "User": {
      "title": "User",
      "description": "Telegram user player profile and progress",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Telegram User ID" },
        "username": { "type": "string" },
        "firstName": { "type": "string" },
        "lang": { "type": "string", "enum": ["be", "ru"] },
        "xp": { "type": "integer", "minimum": 0 },
        "level": { "type": "integer", "minimum": 1 },
        "completedScenarios": { "type": "array", "items": { "type": "integer" } },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "xp", "level", "createdAt"]
    },
    "Log": {
      "title": "Log",
      "description": "Action logs for audit and tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User progress stored by Telegram ID as document ID"
    },
    "logs/{logId}": {
      "schema": "Log",
      "description": "Generic system and user activity logs"
    }
  }
}
